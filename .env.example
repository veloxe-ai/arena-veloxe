# ─── Client (Vite — baked into web build) ────────────────────
VITE_SUPABASE_URL=https://your-supabase-url
VITE_SUPABASE_ANON_KEY=

# ─── Server (orchestrator only — NEVER ship to client) ───────
SUPABASE_URL=https://your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenRouter (required — powers the 3-agent debate) ────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ─── Peec AI (your project ID from peec.ai dashboard) ─────────
PEEC_PROJECT_ID=or_...

# ─── Peec access token (optional — for direct MCP HTTP calls) ─
# Alternative: run peec-pull.sh from a machine with Claude Code + peec-ai MCP auth
# then pass --peec-data path/to/peec-data.json to the orchestrator
PEEC_ACCESS_TOKEN=

# ─── Tier: cheap (~$0.05-0.13/run) | premium (~$0.80/run) ─────
MODEL_TIER=cheap
